generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationChecklistStatus {
  pending
  requested
  received
  verified
  rejected
  waived
}

enum IntakeFormRequestStatus {
  draft
  active
  inactive
  archived
}

enum IntakeFormSubmissionStatus {
  new
  assigned
  contacted
  under_review
  converted
  closed
}

enum NotificationEventStatus {
  pending
  processing
  processed
  failed
}

enum NotificationChannel {
  email
  in_app
  both
}

enum NotificationProvider {
  resend
  suprsend
  system
}

enum NotificationTargetType {
  client
  assigned_user
  branch_admin
  staff
}

enum NotificationDeliveryStatus {
  pending
  sent
  failed
  delivered
  opened
}

enum ClientCommunicationStatus {
  pending
  sent
  failed
}

enum LeadStatus {
  new_lead
  assigned
  contacted
  qualified
  under_review
  converted
  closed
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
}

model Branch {
  id       String  @id @default(cuid())
  name     String
  code     String  @unique
  address  String?
  city     String?
  country  String?
  phone    String?
  email    String?
  isActive Boolean @default(true)

  users              User[]
  clients            Client[]
  intakeFormRequests IntakeFormRequest[]
  intakeSubmissions  IntakeFormSubmission[]
  clientCheckIns     ClientCheckIn[]
  leads              Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  email        String  @unique
  phone        String?
  passwordHash String
  isActive     Boolean @default(true)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  tasksAssignedTo Task[] @relation("TaskAssignedTo")
  tasksAssignedBy Task[] @relation("TaskAssignedBy")

  verifiedChecklistItems     ApplicationChecklistItem[]     @relation("ChecklistVerifiedBy")
  uploadedChecklistDocuments ApplicationChecklistDocument[] @relation("ChecklistUploadedBy")

  createdIntakeFormRequests  IntakeFormRequest[] @relation("IntakeFormCreatedBy")
  assignedIntakeFormRequests IntakeFormRequest[] @relation("IntakeFormAssignedTo")

  assignedIntakeSubmissions IntakeFormSubmission[] @relation("IntakeSubmissionAssignedTo")
  reviewedIntakeSubmissions IntakeFormSubmission[] @relation("IntakeSubmissionReviewedBy")

  createdClients  Client[]         @relation("ClientCreatedBy")
  assignedClients Client[]         @relation("ClientAssignedTo")
  clientFollowers ClientFollower[]

  assignedLeads  Lead[]         @relation("LeadAssignedTo")
  leadFollowers  LeadFollower[]
  leadActivities LeadActivity[]

  auditLogs     AuditLog[]
  notifications Notification[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  importJobs ImportJob[]
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  message     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}


model NotificationEvent {
  id         String                  @id @default(cuid())
  eventType  String
  entityType String
  entityId   String
  payload    Json?
  status     NotificationEventStatus @default(pending)
  error      String?

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  applicationId String?
  application   ClientApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  deliveries NotificationDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([status])
  @@index([workflowId])
  @@index([clientId])
  @@index([taskId])
  @@index([applicationId])
  @@index([createdAt])
}

model WorkflowAutomationRule {
  id          String  @id @default(cuid())
  name        String
  description String?

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  fromStageId String?
  fromStage   WorkflowStage? @relation("AutomationRuleFromStage", fields: [fromStageId], references: [id], onDelete: SetNull)

  toStageId String?
  toStage   WorkflowStage? @relation("AutomationRuleToStage", fields: [toStageId], references: [id], onDelete: SetNull)

  eventType    String
  targetType   NotificationTargetType
  channel      NotificationChannel
  provider     NotificationProvider
  templateKey  String
  delayMinutes Int                    @default(0)
  isActive     Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([fromStageId])
  @@index([toStageId])
  @@index([eventType])
  @@index([isActive])
}

model NotificationDelivery {
  id                  String            @id @default(cuid())
  notificationEventId String
  notificationEvent   NotificationEvent @relation(fields: [notificationEventId], references: [id], onDelete: Cascade)

  provider          NotificationProvider
  channel           NotificationChannel
  recipient         String
  targetType        NotificationTargetType?
  status            NotificationDeliveryStatus @default(pending)
  subject           String?
  body              String?
  providerMessageId String?
  errorMessage      String?

  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  failedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([notificationEventId])
  @@index([provider])
  @@index([channel])
  @@index([status])
  @@index([recipient])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ClientCommunication {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  applicationId String?
  application   ClientApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  provider    NotificationProvider
  channel     NotificationChannel
  templateKey String?

  subject String?
  body    String

  deliveryStatus    ClientCommunicationStatus @default(pending)
  providerMessageId String?
  sentAt            DateTime?
  failedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([applicationId])
  @@index([provider])
  @@index([channel])
  @@index([deliveryStatus])
  @@index([createdAt])
}

model LeadSource {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  clients Client[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workflow {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  clients                 Client[]
  stages                  WorkflowStage[]
  automationRules         WorkflowAutomationRule[]
  notificationEvents      NotificationEvent[]
  taskAutomationTemplates TaskAutomationTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkflowStage {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  stageName     String
  orderSequence Int
  isFinal       Boolean @default(false)

  currentClients      Client[]                 @relation("ClientCurrentStage")
  automationRulesFrom WorkflowAutomationRule[] @relation("AutomationRuleFromStage")
  automationRulesTo   WorkflowAutomationRule[] @relation("AutomationRuleToStage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workflowId, orderSequence])
  @@index([workflowId])
}

model Subagent {
  id           String  @id @default(cuid())
  name         String
  contact      String?
  email        String?
  phone        String?
  country      String?
  referralCode String  @unique
  isActive     Boolean @default(true)

  clients           Client[]
  leads             Lead[]
  intakeSubmissions IntakeFormSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([name])
  @@index([country])
}

model Provider {
  id          String  @id @default(cuid())
  name        String
  code        String? @unique
  country     String?
  city        String?
  email       String?
  phone       String?
  website     String?
  description String?
  isActive    Boolean @default(true)

  legalName       String?
  defaultCurrency String?
  supportEmail    String?
  supportPhone    String?
  admissionEmail  String?
  financeEmail    String?
  applicationUrl  String?
  portalUrl       String?
  logoUrl         String?
  address         String?
  notes           String?

  syncStatus      String?
  lastSyncAt      DateTime?
  lastSyncMessage String?
  autoSyncEnabled Boolean   @default(false)
  sourceType      String?

  courses      Course[]
  applications ClientApplication[]
  contacts     ProviderContact[]
  campuses     ProviderCampus[]
  syncSources  ProviderSyncSource[]
  syncLogs     ProviderSyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@index([isActive])
  @@index([country])
  @@index([city])
  @@index([syncStatus])
  @@index([lastSyncAt])
}

model Course {
  id           String  @id @default(cuid())
  providerId   String
  name         String
  level        String?
  duration     String?
  tuitionFee   Float?
  intakeMonths String?
  campus       String?
  description  String?
  isActive     Boolean @default(true)

  code                String?
  category            String?
  studyMode           String?
  durationValue       Float?
  durationUnit        String?
  applicationFee      Float?
  materialFee         Float?
  currency            String?
  entryRequirements   String?
  englishRequirements String?
  notes               String?
  sourceType          String?
  syncStatus          String?

  provider     Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  applications ClientApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, name])
  @@index([providerId])
}

model ProviderContact {
  id         String  @id @default(cuid())
  providerId String
  fullName   String
  role       String?
  department String?
  email      String?
  phone      String?
  whatsapp   String?
  location   String?
  notes      String?
  isPrimary  Boolean @default(false)
  isActive   Boolean @default(true)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([isPrimary])
  @@index([isActive])
  @@index([email])
}

model ProviderCampus {
  id         String  @id @default(cuid())
  providerId String
  name       String
  city       String?
  state      String?
  country    String?
  address    String?
  notes      String?
  isActive   Boolean @default(true)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([isActive])
  @@index([city])
  @@index([country])
}

model ProviderSyncSource {
  id              String  @id @default(cuid())
  providerId      String
  sourceType      String
  name            String?
  endpointUrl     String?
  authType        String?
  authConfig      Json?
  mappingConfig   Json?
  autoSyncEnabled Boolean @default(false)
  isActive        Boolean @default(true)

  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?

  provider Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  syncLogs ProviderSyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([sourceType])
  @@index([isActive])
  @@index([lastSyncAt])
  @@index([lastSyncStatus])
}

model ProviderSyncLog {
  id           String  @id @default(cuid())
  providerId   String
  syncSourceId String?

  status        String
  startedAt     DateTime
  finishedAt    DateTime?
  createdCount  Int       @default(0)
  updatedCount  Int       @default(0)
  archivedCount Int       @default(0)
  skippedCount  Int       @default(0)
  errorMessage  String?
  rawSummary    Json?

  provider   Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  syncSource ProviderSyncSource? @relation(fields: [syncSourceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([providerId])
  @@index([syncSourceId])
  @@index([status])
  @@index([startedAt])
  @@index([createdAt])
}

model Client {
  id          String  @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String
  passport    String?
  profileData Json?

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  sourceId String?
  source   LeadSource? @relation(fields: [sourceId], references: [id])

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id])

  currentStageId String?
  currentStage   WorkflowStage? @relation("ClientCurrentStage", fields: [currentStageId], references: [id])

  subagentId String?
  subagent   Subagent? @relation(fields: [subagentId], references: [id])

  createdById String?
  createdBy   User?   @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("ClientAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  intakeSubmissions IntakeFormSubmission[]

  originalIntakeSubmissionId String?               @unique
  originalIntakeSubmission   IntakeFormSubmission? @relation("ClientOriginalIntakeSubmission", fields: [originalIntakeSubmissionId], references: [id], onDelete: SetNull)

  tasks              Task[]
  activities         ClientActivity[]
  notes              ClientNote[]
  documents          ClientDocument[]
  applications       ClientApplication[]
  notificationEvents NotificationEvent[]
  communications     ClientCommunication[]
  checkIns           ClientCheckIn[]
  leads              Lead[]
  followers          ClientFollower[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([assignedToId])
}

model ClientApplication {
  id            String    @id @default(cuid())
  clientId      String
  providerId    String
  courseId      String
  intake        String
  intakeYear    Int?
  status        String    @default("applied")
  applicationNo String?
  notes         String?
  appliedAt     DateTime?
  offerDate     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client             Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider           Provider                   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  course             Course                     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  journey            ApplicationJourney?
  checklistItems     ApplicationChecklistItem[]
  notificationEvents NotificationEvent[]
  communications     ClientCommunication[]

  @@index([clientId])
  @@index([providerId])
  @@index([courseId])
  @@index([status])
  @@index([intake, intakeYear])
}

model ApplicationJourney {
  id            String @id @default(cuid())
  applicationId String @unique

  offerStatus     String    @default("not_started")
  offerType       String?
  offerConditions String?
  offerReceivedAt DateTime?
  offerAcceptedAt DateTime?

  coeStatus   String    @default("not_started")
  coeNumber   String?
  coeIssuedAt DateTime?

  visaStatus     String    @default("not_started")
  visaFileNumber String?
  visaLodgedAt   DateTime?
  visaGrantedAt  DateTime?
  visaRefusedAt  DateTime?
  visaExpiryDate DateTime?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application ClientApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([offerStatus])
  @@index([coeStatus])
  @@index([visaStatus])
  @@index([visaExpiryDate])
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  assignedToId String
  assignedTo   User   @relation("TaskAssignedTo", fields: [assignedToId], references: [id])

  assignedById String
  assignedBy   User   @relation("TaskAssignedBy", fields: [assignedById], references: [id])

  status  String    @default("pending")
  dueDate DateTime?

  reminderEnabled    Boolean   @default(true)
  lastReminderSentAt DateTime?
  reminderCount      Int       @default(0)

  notificationEvents NotificationEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientActivity {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  message   String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}

model ClientDocument {
  id        String   @id @default(cuid())
  clientId  String
  title     String
  fileName  String
  filePath  String
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
}

model DocumentRequirementTemplate {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  category    String?
  isRequired  Boolean  @default(true)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  allowMulti  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklistItems ApplicationChecklistItem[]
}

model ApplicationChecklistItem {
  id            String                     @id @default(cuid())
  applicationId String
  templateId    String?
  title         String
  description   String?
  category      String?
  isRequired    Boolean                    @default(true)
  status        ApplicationChecklistStatus @default(pending)
  remarks       String?
  dueDate       DateTime?
  sortOrder     Int                        @default(0)
  verifiedAt    DateTime?
  verifiedById  String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  application ClientApplication              @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  template    DocumentRequirementTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  verifiedBy  User?                          @relation("ChecklistVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  documents   ApplicationChecklistDocument[]

  @@index([applicationId])
  @@index([templateId])
  @@index([verifiedById])
}

model ApplicationChecklistDocument {
  id              String   @id @default(cuid())
  checklistItemId String
  uploadedById    String?
  title           String
  fileName        String
  filePath        String
  fileType        String?
  fileSize        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  checklistItem ApplicationChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  uploadedBy    User?                    @relation("ChecklistUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([checklistItemId])
  @@index([uploadedById])
}

model IntakeFormRequest {
  id           String  @id @default(cuid())
  branchId     String
  createdById  String
  assignedToId String?
  token        String  @unique

  title       String
  description String?
  status      IntakeFormRequestStatus @default(draft)
  isActive    Boolean                 @default(true)

  publicUrl        String?
  qrCodeValue      String?
  submitButtonText String? @default("Submit")
  successMessage   String? @default("Thank you. Your form has been submitted successfully.")

  formSchema Json?
  settings   Json?
  notes      String?

  sharedAt        DateTime?
  expiresAt       DateTime?
  lastSubmittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("IntakeFormCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo  User?                  @relation("IntakeFormAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  submissions IntakeFormSubmission[]

  @@index([branchId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([token])
}

model IntakeFormSubmission {
  id                  String  @id @default(cuid())
  intakeFormRequestId String
  branchId            String
  assignedToId        String?
  reviewedById        String?
  clientId            String?
  subagentId          String?

  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  country        String?
  city           String?
  address        String?
  nationality    String?
  dateOfBirth    DateTime?
  passportNumber String?
  notes          String?

  answers        Json?
  submittedFiles Json?
  submissionMeta Json?

  status        IntakeFormSubmissionStatus @default(new)
  submittedAt   DateTime                   @default(now())
  assignedAt    DateTime?
  reviewedAt    DateTime?
  convertedAt   DateTime?
  closedAt      DateTime?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intakeFormRequest IntakeFormRequest @relation(fields: [intakeFormRequestId], references: [id], onDelete: Cascade)
  branch            Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo        User?             @relation("IntakeSubmissionAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  reviewedBy        User?             @relation("IntakeSubmissionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  client            Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  subagent          Subagent?         @relation(fields: [subagentId], references: [id], onDelete: SetNull)

  originalForClient Client?         @relation("ClientOriginalIntakeSubmission")
  checkIns          ClientCheckIn[]
  lead              Lead?

  @@index([intakeFormRequestId])
  @@index([branchId])
  @@index([assignedToId])
  @@index([reviewedById])
  @@index([clientId])
  @@index([subagentId])
  @@index([status])
  @@index([submittedAt])
}

model TaskAutomationTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  triggerEventType String
  triggerStatus    String?

  sourceTaskTitle String?
  sourceStageId   String?

  titleTemplate       String
  descriptionTemplate String?

  assignToType String
  offsetDays   Int    @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([triggerEventType])
  @@index([isActive])
}

model ClientCheckIn {
  id String @id @default(cuid())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  intakeSubmissionId String?
  intakeSubmission   IntakeFormSubmission? @relation(fields: [intakeSubmissionId], references: [id], onDelete: SetNull)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  checkInMethod String  @default("qr")
  visitReason   String?
  notes         String?

  checkedInAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]

  @@index([clientId, checkedInAt])
  @@index([intakeSubmissionId, checkedInAt])
  @@index([branchId, checkedInAt])
}

model Lead {
  id String @id @default(cuid())

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  intakeSubmissionId String?               @unique
  intakeSubmission   IntakeFormSubmission? @relation(fields: [intakeSubmissionId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  clientCheckInId String?
  clientCheckIn   ClientCheckIn? @relation(fields: [clientCheckInId], references: [id], onDelete: SetNull)

  agentId String?
  agent   Subagent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  passportNumber String?
  country        String?

  source String?

  status LeadStatus @default(new_lead)

  assignedToId String?
  assignedTo   User?   @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  assignedAt DateTime?

  notes String?

  lastActivityAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  followers  LeadFollower[]
  activities LeadActivity[]

  @@index([branchId])
  @@index([assignedToId])
  @@index([agentId])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([passportNumber])
  @@index([country])
  @@index([source])
}

model LeadFollower {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([leadId, userId])
  @@index([userId])
}

model LeadActivity {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  action  String
  details Json?

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([actorUserId])
}

model ClientFollower {
  id String @id @default(cuid())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clientId, userId])
  @@index([userId])
}

model CommunicationTemplate {
  id          String              @id @default(cuid())
  name        String
  key         String              @unique
  description String?
  channel     NotificationChannel
  subject     String?
  body        String
  isActive    Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([channel])
  @@index([isActive])
  @@index([createdAt])
}

model ImportJob {
  id          String  @id @default(cuid())
  type        String
  sourceType  String
  sourceValue String?
  status      String

  totalRows    Int @default(0)
  validRows    Int @default(0)
  invalidRows  Int @default(0)
  importedRows Int @default(0)
  skippedRows  Int @default(0)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rows ImportJobRow[]

  @@index([type])
  @@index([sourceType])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model ImportJobRow {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  rawRowIndex  Int?
  providerName String?
  courseName   String?
  payloadJson  Json?

  isValid     Boolean @default(false)
  isDuplicate Boolean @default(false)
  wasImported Boolean @default(false)

  errors String[]

  createdAt DateTime @default(now())

  @@index([importJobId])
  @@index([rawRowIndex])
  @@index([isValid])
  @@index([isDuplicate])
}
